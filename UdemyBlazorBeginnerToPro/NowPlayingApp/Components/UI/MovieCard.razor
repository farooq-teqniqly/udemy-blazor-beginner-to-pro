<div class="card h-100 movie-card">
    <div
        class="movie-card-poster @(_isPosterLoading ? "movie-card-poster--busy" : null)"
        aria-busy="@_isPosterLoading"
    >
        @if (_isPosterLoading)
        {
            <div class="movie-card-poster__spinner" aria-hidden="true">
                <LoadingSpinner Label="Loading poster" />
            </div>
        }
        <img
            src="@_posterSrc"
            alt="@Movie.Title"
            class="card-img-top movie-card-poster__image @(_isPosterLoading ? "movie-card-poster__image--loading" : null)"
            @onload="HandlePosterLoad"
            @onerror="HandlePosterError" />
    </div>
    <div class="card-body border border-top">
        <div class="card-title fw-bold lh-1">@Movie.Title</div>
        <div class="card-text lh-1 fst-italic">Release date: @GetFormattedDate(Movie.ReleaseDate)</div>
    </div>
    <div class="card-footer d-flex justify-content-between movie-card-footer">
        <button class="btn btn-outline-primary" @onclick="HandleToggleFavoriteAsync">
            @(IsFavorite ? "Remove favorite" : "Add favorite")
        </button>
        <a href="moviedetail" class="btn btn-primary">More info</a>
    </div>
</div>
