@page "/now-playing"
@inject TMDBClient TMDBClient
@inject ILogger<NowPlayingPage> Logger

<PageTitle>Now Playing</PageTitle>
<div>
    <h1>
        <i class="bi bi-film text-primary"></i>
        Now Playing
    </h1>
    <p class="lead italic">Movies that are now playing in theaters.</p>
    <MovieList Movies="_nowPlayingMovies" IsLoading="_isLoading" CategoryLabel="Now Playing" />
</div>

@code {
    private CancellationTokenSource? _cancellationTokenSource;
    private List<MovieResponse>? _nowPlayingMovies;
    private bool _isLoading;

    protected override async Task OnInitializedAsync()
    {
        _cancellationTokenSource = new CancellationTokenSource();
        _isLoading = true;

        try
        {
            var response = await TMDBClient.GetNowPlayingMovies(cancellationToken: _cancellationTokenSource.Token);
            _nowPlayingMovies = response.Results;
        }
        catch (OperationCanceledException)
        {
            Logger.LogDebug($"{nameof(TMDBClient.GetNowPlayingMovies)} request was cancelled.");
        }
        catch (HttpRequestException httpRequestException)
        {
            Logger.LogError(httpRequestException, $"{nameof(TMDBClient.GetNowPlayingMovies)} - an error occurred.");
        }
        finally
        {
            _isLoading = false;
        }

    }

    public void Dispose()
    {
        _cancellationTokenSource?.Cancel();
        _cancellationTokenSource?.Dispose();
    }
}
