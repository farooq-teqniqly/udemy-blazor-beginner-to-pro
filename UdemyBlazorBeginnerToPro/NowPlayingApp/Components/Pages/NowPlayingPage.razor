@page "/now-playing"

<PageTitle>Now Playing</PageTitle>
<div>
    <h1>
        <i class="bi bi-film text-primary"></i>
        Now Playing
    </h1>
    <p class="lead italic">Movies that are now playing in theaters.</p>
    <div class="row g-3 row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4">
        @for (var i = 0; i < 20; i++)
        {
            <div class="col">
                <MovieCard></MovieCard>
            </div>
        }
    </div>
</div>

