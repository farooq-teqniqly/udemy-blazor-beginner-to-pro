@page "/themes"
@using BlazorLayout.Services
@inject ThemeService ThemeService

<PageTitle>Template Themes</PageTitle>

<div class="mt-5">
    <h1 class="text-center">Built in themes for your template</h1>
    
    <div class="d-flex flex-wrap gap-3 align-items-center justify-content-center my-3">
        @foreach (var theme in ThemeService.Themes)
        {
            <div class="card" data-cf-theme="@theme">
                <div class="card-body">
                    <h3 class="card-title d-flex align-items-center">
                        Theme:&nbsp;<span style="color: var(--cf-theme-core)">@theme</span>
                        <button class="ms-auto btn btn-small btn-primary" @onclick="() => ThemeService.ChangeThemeAsync(theme)">Apply Theme</button>
                    </h3>
                    <h6 class="small fw-bold mt-3">Palette</h6>
                    <div class="d-flex gap-0 align-items-center">
                        @foreach (var weight in ThemeService.Weights)
                        {
                            <div style="background-color: var(--cf-@theme-@weight); width: 16px; height: 16px"></div>
                        }
                    </div>
                    <div class="my-3">
                        <button class="btn btn-primary m2">Primary Button</button>
                        <button class="btn btn-light m2">Light Button</button>
                        <button class="btn btn-dark m2">Dark Button</button>
                    </div>
                    <div>
                        Text with a <a href="#">clickable link</a> in the middle.
                    </div>
                </div>
            </div>
        }
    </div>
</div>

