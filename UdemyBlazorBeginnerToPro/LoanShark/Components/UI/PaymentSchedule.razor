<div class="mt-5 border border-1 p-4">
    @if (PaymentScheduleRows.Count > 0)
    {
        <h2 class="mb-4">Payment Schedule</h2>
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-primary">
                    <tr>
                        <th>Month</th>
                        <th>Payment</th>
                        <th>Principal</th>
                        <th>Interest</th>
                        <th>Total Interest</th>
                        <th>Balance</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in PaymentScheduleRows)
                    {
                        <tr>
                            <td>@row.Month</td>
                            <td>@row.Payment.ToString("C")</td>
                            <td>@row.Principal.ToString("C")</td>
                            <td>@row.Interest.ToString("C")</td>
                            <td>@row.TotalInterest.ToString("C")</td>
                            <td>@row.Balance.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p>No payments to display. Enter some values and press calculate to see loan payments.</p>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public List<PaymentScheduleRowViewModel> PaymentScheduleRows { get; set; } = [];

}
